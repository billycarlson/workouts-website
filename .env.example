# =============================================================================
# Local dev only — copy this file to `.env.local` (git ignores `.env.local`).
#
# Production gets DATABASE_URL from Vercel. Your laptop does NOT unless you
# create this file yourself. That’s normal, not a bug.
# =============================================================================

# You only need ONE variable for this app:
DATABASE_URL="paste-your-postgres-url-here"

# -----------------------------------------------------------------------------
# Where to get the value (pick one):
#
# A) Vercel dashboard (easiest if the live site already works)
#    1. https://vercel.com/dashboard → workouts-website project
#    2. Settings → Environment Variables
#    3. Copy DATABASE_URL (Development or Production — same DB is fine)
#    4. Paste between the quotes above
#
# B) Vercel CLI (auto-creates .env.local)
#    vercel login
#    cd /path/to/workouts-website
#    vercel link
#    vercel env pull .env.local
#
# C) Railway (if that’s where the DB lives)
#    1. railway.app → your Postgres service → Connect
#    2. Copy the PUBLIC URL (*.proxy.rlwy.net), not the private one
#    3. Paste between the quotes above
#
# Example shape (fake values):
# DATABASE_URL="postgresql://postgres:SECRET@shortline.proxy.rlwy.net:12345/railway?sslmode=require"
# -----------------------------------------------------------------------------

# After saving .env.local:
#   npm run db:push   # only needed once on a fresh database
#   npm run dev
#   open http://localhost:3000/profiles
